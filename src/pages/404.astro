---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found | CHINPK Packaging"
  description="Page not found - CHINPK Packaging"
  noindex={true}
>
  <section class="py-20 min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-gray-200 mb-4">404</h1>
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Page Not Found</h2>
      <p class="text-gray-600 mb-8 max-w-md mx-auto">The page you're looking for doesn't exist or has been moved. Let us help you find what you need.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="btn-primary">Go to Homepage</a>
        <a href="/products" class="inline-block bg-gray-100 text-gray-700 px-8 py-3 rounded-md font-semibold hover:bg-gray-200 transition-colors">Browse Products</a>
        <a href="/contact" class="inline-block bg-gray-100 text-gray-700 px-8 py-3 rounded-md font-semibold hover:bg-gray-200 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
