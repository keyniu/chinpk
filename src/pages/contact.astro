---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | CHINPK - Get Instant Packaging Quote"
  description="Contact CHINPK Packaging - Get instant quote for plastic packaging. Email: sales@chinpk.com, Phone: +86 159 3948 2575, WhatsApp available."
>
  <div class="breadcrumb"><div class="container"><a href="/">Home</a><span class="separator">/</span><span class="current">Contact Us</span></div></div>

  <section class="page-header text-center"><div class="container"><h1>Contact Us</h1><p>Get in touch with our packaging specialists for a free quote.</p></div></section>

  <section class="py-20"><div class="container"><div class="grid lg:grid-cols-2 gap-16">
    <div class="reveal-left">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Request a Quote</h2>
      <p class="text-gray-600 mb-8">Fill out the form and our sales team will respond within 24 hours.</p>

      <div id="inquiry-summary" class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6 hidden">
        <div class="flex items-start gap-3">
          <i class="fas fa-info-circle mt-1" style="color:var(--color-primary)"></i>
          <div><p class="font-semibold text-gray-900">You're inquiring about:</p><p id="inquiry-product-name" class="font-medium" style="color:var(--color-primary)"></p></div>
          <button type="button" id="clear-inquiry" class="ml-auto text-gray-400 hover:text-gray-600" onclick="window.clearInquiry?.()"><i class="fas fa-times"></i></button>
        </div>
      </div>

      <form id="contact-form" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div><label for="name" class="form-label">Your Name *</label><input type="text" id="name" name="name" required class="form-input" /><div class="form-error">Please enter your name</div></div>
          <div><label for="company" class="form-label">Company Name</label><input type="text" id="company" name="company" class="form-input" /></div>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div><label for="email" class="form-label">Email Address *</label><input type="email" id="email" name="email" required class="form-input" /><div class="form-error">Please enter a valid email</div></div>
          <div><label for="phone" class="form-label">Phone / WhatsApp</label><input type="tel" id="phone" name="phone" class="form-input" /></div>
        </div>
        <div><label for="product" class="form-label">Product Interest</label>
          <select id="product" name="product" class="form-input">
            <option value="">Select Product Category</option>
            <option value="cans">PET Plastic Cans</option>
            <option value="jars">Plastic Jars</option>
            <option value="bottles">Plastic Bottles</option>
            <option value="custom">Custom Packaging</option>
            <option value="other">Other Products</option>
          </select>
        </div>
        <div><label for="quantity" class="form-label">Estimated Quantity</label>
          <select id="quantity" name="quantity" class="form-input">
            <option value="">Select Quantity Range</option>
            <option value="5000">5,000 - 10,000 pcs</option>
            <option value="10000">10,000 - 50,000 pcs</option>
            <option value="50000">50,000 - 100,000 pcs</option>
            <option value="100000">100,000+ pcs</option>
          </select>
        </div>
        <div><label for="message" class="form-label">Your Requirements *</label><textarea id="message" name="message" rows="5" placeholder="Please describe your requirements..." class="form-input resize-none"></textarea><div class="form-error">Please describe your requirements</div></div>
        <button type="submit" class="w-full text-white px-8 py-4 rounded-md font-semibold transition-colors text-lg" style="background:var(--color-primary)"><i class="fas fa-paper-plane mr-2"></i>Send Inquiry</button>
      </form>
    </div>

    <div class="reveal-right">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Contact Information</h2>
      <div class="flex flex-wrap gap-3 mb-6">
        <span class="inline-flex items-center gap-1 bg-green-50 border border-green-200 rounded-full px-3 py-1.5 text-xs font-medium" style="color:var(--color-primary)"><i class="fas fa-check-circle"></i> 4.8/5 Rating</span>
        <span class="inline-flex items-center gap-1 bg-green-50 border border-green-200 rounded-full px-3 py-1.5 text-xs font-medium" style="color:var(--color-primary)"><i class="fas fa-clock"></i> ≤2h Response</span>
        <span class="inline-flex items-center gap-1 bg-green-50 border border-green-200 rounded-full px-3 py-1.5 text-xs font-medium" style="color:var(--color-primary)"><i class="fas fa-reply"></i> 98.7% Rate</span>
        <span class="inline-flex items-center gap-1 bg-green-50 border border-green-200 rounded-full px-3 py-1.5 text-xs font-medium" style="color:var(--color-primary)"><i class="fas fa-star"></i> Verified</span>
      </div>
      <p class="text-gray-600 mb-6">Contact our export manager directly:</p>
      <div class="bg-white rounded-lg border border-gray-200 p-5 mb-8"><div class="flex items-center gap-4"><div class="w-14 h-14 rounded-full flex items-center justify-center text-white font-bold text-lg" style="background:var(--color-primary)">CY</div><div><h3 class="font-bold text-gray-900">Ms. Crystal Yuan</h3><p class="text-gray-500 text-sm">Export Manager</p><a href="mailto:sales@chinpk.com" class="text-sm hover:underline" style="color:var(--color-primary)">sales@chinpk.com</a></div></div></div>
      <div class="space-y-6 mb-10">
        <div class="flex items-start"><div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 mr-4" style="background:var(--color-primary)"><i class="fas fa-envelope text-white"></i></div><div><h3 class="font-bold text-gray-900 mb-1">Email</h3><a href="mailto:sales@chinpk.com" class="hover:underline" style="color:var(--color-primary)">sales@chinpk.com</a><p class="text-gray-500 text-sm">Response within 2 hours</p></div></div>
        <div class="flex items-start"><div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 mr-4" style="background:var(--color-primary)"><i class="fas fa-phone text-white"></i></div><div><h3 class="font-bold text-gray-900 mb-1">Phone</h3><a href="tel:+8615939482575" class="hover:underline" style="color:var(--color-primary)">+86 159 3948 2575</a><p class="text-gray-500 text-sm">Mon-Fri, 9:00-18:00 (GMT+8)</p></div></div>
        <div class="flex items-start"><div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 mr-4" style="background:var(--color-whatsapp)"><i class="fab fa-whatsapp text-white"></i></div><div><h3 class="font-bold text-gray-900 mb-1">WhatsApp (Fastest)</h3><a href="https://wa.me/8615939482575" target="_blank" class="hover:underline font-medium" style="color:var(--color-whatsapp)">+86 159 3948 2575</a><p class="text-gray-500 text-sm">Available 24/7</p></div></div>
        <div class="flex items-start"><div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 mr-4" style="background:var(--color-wechat)"><i class="fab fa-weixin text-white"></i></div><div><h3 class="font-bold text-gray-900 mb-1">WeChat</h3><p class="text-gray-700">CHINPK_Sales</p></div></div>
        <div class="flex items-start"><div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 mr-4" style="background:var(--color-primary)"><i class="fas fa-map-marker-alt text-white"></i></div><div><h3 class="font-bold text-gray-900 mb-1">Factory Address</h3><p class="text-gray-600">No. 88 Industrial Zone<br/>Guangzhou, Guangdong, China</p></div></div>
      </div>
      <div class="mt-8 p-6 bg-gray-50 rounded-lg"><h3 class="font-bold text-gray-900 mb-4"><i class="fas fa-clock mr-2" style="color:var(--color-primary)"></i>Business Hours</h3><div class="space-y-2 text-gray-600"><div class="flex justify-between"><span>Mon-Fri</span><span class="font-medium">9:00 AM - 6:00 PM</span></div><div class="flex justify-between"><span>Saturday</span><span class="font-medium">9:00 AM - 1:00 PM</span></div><div class="flex justify-between"><span>Sunday</span><span class="font-medium text-gray-400">Closed</span></div></div><p class="text-sm text-gray-500 mt-4">* WhatsApp responded 7 days a week</p></div>
    </div>
  </div></div></section>

  <section class="py-20 bg-[#f0f7f3] reveal"><div class="container text-center"><h2 class="text-3xl lg:text-4xl font-bold text-white mb-6" style="color:#1f2937">Need Custom Packaging?</h2><p class="text-gray-600 text-lg mb-10">Contact us for a free consultation.</p><a href="tel:+8615939482575" class="inline-block text-white px-10 py-4 rounded-md font-semibold transition-colors text-lg" style="background:var(--color-primary)">Call Now: +86 159 3948 2575</a></div></section>
</BaseLayout>
