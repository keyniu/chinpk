---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Industry Solutions | CHINPK - Packaging for Food, Cosmetic, Pharma"
  description="CHINPK industry packaging solutions for food & beverage, cosmetics, pharmaceutical, and personal care industries."
>
  <div class="breadcrumb"><div class="container"><a href="/">Home</a><span class="separator">/</span><span class="current">Industry Solutions</span></div></div>

  <section class="page-header text-center"><div class="container"><h1>Industry Solutions</h1><p>Specialized packaging solutions for food, beverage, cosmetic, pharmaceutical, and personal care industries.</p></div></section>

  <section class="py-20"><div class="container">
    <div class="text-center mb-16 reveal"><h2 class="text-3xl font-bold text-gray-900 mb-4">Packaging Solutions by Industry</h2></div>

    <!-- Food & Beverage -->
    <article class="mb-20 reveal"><div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="w-16 h-16 rounded-lg flex items-center justify-center mb-6" style="background:var(--color-primary)"><i class="fas fa-utensils text-white text-2xl"></i></div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Food &amp; Beverage Industry</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">Food-safe packaging solutions that preserve freshness and meet stringent food contact regulations. Our food grade PET containers are FDA and LFGB compliant.</p>
        <h4 class="font-bold text-gray-900 mb-3">Recommended Products:</h4>
        <ul class="text-gray-600 space-y-2 mb-6">
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>PET Plastic Cans for nuts, candies, snacks</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Wide Mouth Jars for spices and dry ingredients</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Beverage Bottles for juices and water</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Aluminum Easy-Open Lids for beverage cans</li>
        </ul>
        <a href="/contact" class="btn-primary">Get Food Packaging Quote</a>
      </div>
      <div><img src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=700&h=500&fit=crop" alt="Food & Beverage Packaging" class="w-full rounded-lg shadow-lg" width="700" height="500" loading="lazy" decoding="async" /></div>
    </div></article>

    <!-- Cosmetics -->
    <article class="mb-20 reveal delay-2"><div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1"><img src="https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?w=700&h=500&fit=crop" alt="Cosmetic Packaging" class="w-full rounded-lg shadow-lg" width="700" height="500" loading="lazy" decoding="async" /></div>
      <div class="order-1 lg:order-2">
        <div class="w-16 h-16 rounded-lg flex items-center justify-center mb-6" style="background:var(--color-primary)"><i class="fas fa-spa text-white text-2xl"></i></div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Cosmetics &amp; Beauty Industry</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">Premium quality cosmetic packaging that combines elegance with functionality.</p>
        <h4 class="font-bold text-gray-900 mb-3">Recommended Products:</h4>
        <ul class="text-gray-600 space-y-2 mb-6">
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Clear PET Jars for creams and masks</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Amber Jars for UV-sensitive products</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Pump Bottles for lotions and serums</li>
        </ul>
        <a href="/contact" class="btn-primary">Get Cosmetic Packaging Quote</a>
      </div>
    </div></article>

    <!-- Pharmaceutical -->
    <article class="mb-20 reveal delay-4"><div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="w-16 h-16 rounded-lg flex items-center justify-center mb-6" style="background:var(--color-primary)"><i class="fas fa-pills text-white text-2xl"></i></div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Pharmaceutical &amp; Healthcare</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">Pharmaceutical-grade packaging that meets the strictest regulatory requirements.</p>
        <h4 class="font-bold text-gray-900 mb-3">Recommended Products:</h4>
        <ul class="text-gray-600 space-y-2 mb-6">
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>HDPE Pill Bottles with CRC caps</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Pharmaceutical Grade Containers</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Vitamin and Supplement Jars</li>
        </ul>
        <a href="/contact" class="btn-primary">Get Pharma Packaging Quote</a>
      </div>
      <div><img src="https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=700&h=500&fit=crop" alt="Pharmaceutical Packaging" class="w-full rounded-lg shadow-lg" width="700" height="500" loading="lazy" decoding="async" /></div>
    </div></article>

    <!-- Personal Care -->
    <article class="reveal delay-6"><div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1"><img src="https://images.unsplash.com/photo-1556228578-0d85b1746585?w=700&h=500&fit=crop" alt="Personal Care Packaging" class="w-full rounded-lg shadow-lg" width="700" height="500" loading="lazy" decoding="async" /></div>
      <div class="order-1 lg:order-2">
        <div class="w-16 h-16 rounded-lg flex items-center justify-center mb-6" style="background:var(--color-primary)"><i class="fas fa-hand-sparkles text-white text-2xl"></i></div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Personal Care &amp; Household</h3>
        <p class="text-gray-600 mb-6 leading-relaxed">Durable and functional packaging for personal care and household products.</p>
        <h4 class="font-bold text-gray-900 mb-3">Recommended Products:</h4>
        <ul class="text-gray-600 space-y-2 mb-6">
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>HDPE Squeeze Bottles for hair care</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Spray Bottles for body mists</li>
          <li><i class="fas fa-check mr-2" style="color:var(--color-primary)"></i>Household Cleaner Bottles</li>
        </ul>
        <a href="/contact" class="btn-primary">Get Personal Care Quote</a>
      </div>
    </div></article>
  </div></section>

  <section class="py-20 reveal" style="background:var(--color-primary)"><div class="container text-center"><h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">Find Your Perfect Packaging Solution</h2><p class="text-green-100 text-lg mb-10">Contact our specialists to discuss your specific industry requirements.</p><a href="/contact" class="btn-white">Discuss Your Project</a></div></section>
</BaseLayout>
